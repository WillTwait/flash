Output assets/demo.gif
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set Shell "zsh"

Hide
Type "cd ~/Developer/flash-demo"
Enter
Sleep 1s
Show

# Flash into — fzf picker
Type "flash into"
Enter
Sleep 1s
Up
Sleep 500ms
Up
Sleep 500ms
Enter
Sleep 2s

# Check status
Type "flash status"
Enter
Sleep 2s

# Apply changes to worktree
Type "flash apply"
Enter
Sleep 2s

# Flash out
Type "flash out --discard"
Enter
Sleep 2s
